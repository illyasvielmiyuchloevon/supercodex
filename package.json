{
  "name": "@eirui/supercodex",
  "version": "0.13.1",
  "type": "module",
  "description": "SuperCodex app-server controller for resumable long-running software delivery loops.",
  "bin": {
    "supercodex": "dist/src/cli.js"
  },
  "files": [
    "dist/src/",
    "AGENTS.md",
    "README.md",
    "README.zh-CN.md",
    "LICENSE",
    "dosc/USAGE_GUIDE.md",
    "dosc/USAGE_GUIDE.zh-CN.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "prebuild": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "tsc -p tsconfig.json",
    "prepack": "npm run build",
    "prepublishOnly": "npm test",
    "test": "npm run build && node --test dist/tests/*.test.js && npm run test:opentui",
    "test:node": "npm run build && node --test dist/tests/*.test.js",
    "test:opentui": "bun test tests/opentui-smoke.test.tsx",
    "doctor": "node dist/src/cli.js doctor --project .",
    "status": "node dist/src/cli.js status --project ."
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/bun": "^1.3.13",
    "@types/node": "^24.0.0",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "@opentui/core": "0.1.97",
    "@opentui/solid": "0.1.97",
    "solid-js": "1.9.11"
  },
  "license": "MIT"
}
